---
import Shell from "../layouts/Shell.astro";
import EmblemGenerator from "../components/EmblemGenerator.tsx";
---
<Shell>
  <section class="hero">
    <div class="hero__left">
      <h1 class="hero__title">Emblem Generator</h1>
      <p class="hero__sub">Create on-brand Logos assets. Add text, pick a theme, overlay the logomark.</p>
    </div>
  </section>

  <EmblemGenerator client:load />
</Shell>
