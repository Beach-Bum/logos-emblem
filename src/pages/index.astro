---
import Shell from "../layouts/Shell.astro";
import EmblemGenerator from "../components/EmblemGenerator.tsx";
---
<Shell>
  <section class="hero">
    <span class="hero__tag">/emblem</span>
    <h1 class="hero__title">Emblem Generator</h1>
    <p class="hero__desc">
      Create on-brand Logos assets — social posts, posters, stickers, memes.
      Upload an image, pick a theme, add text, overlay the lambda. Download as PNG or SVG.
    </p>
  </section>

  <EmblemGenerator client:load />
</Shell>
