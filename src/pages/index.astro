---
import Shell from "../layouts/Shell.astro";
import EmblemGenerator from "../components/EmblemGenerator.tsx";
---
<Shell>
  <section class="hero">
    <div class="hero__left">
      <a href="/" class="hero__back">
        <span class="hero__back-arrow">←</span>
        <span>Tools</span>
      </a>
      <div class="hero__title-row">
        <img src="/assets/img/logomark.svg" alt="" class="hero__mark" width="20" height="26" />
        <h1 class="hero__title">Emblem Generator</h1>
      </div>
    </div>
    <div class="hero__center">
      <p class="hero__desc">
        Create on-brand Logos assets — social posts, posters, stickers, memes.
        Upload an image, pick a theme, add text, overlay the logomark. Download as PNG or SVG.
      </p>
      <div class="hero__meta">
        <p class="hero__meta-heading">Formats:</p>
        <div class="hero__meta-list">
          <p><span class="hero__meta-key">Square</span> — 1080×1080 social</p>
          <p><span class="hero__meta-key">Story</span> — 1080×1920 vertical</p>
          <p><span class="hero__meta-key">Landscape</span> — 1200×628 link preview</p>
          <p><span class="hero__meta-key">Poster</span> — A2 print (1414×2000)</p>
          <p><span class="hero__meta-key">Sticker</span> — 1080×1080 circle</p>
        </div>
      </div>
    </div>
    <div class="hero__right">
      <a href="https://logos.co/brand-guidelines" class="hero__cta-link">
        <span>Brand Guidelines</span>
        <span class="hero__cta-arrow">→</span>
      </a>
      <a href="https://github.com/Beach-Bum/logos-emblem" class="hero__cta-link">
        <span>Repo</span>
        <span class="hero__cta-arrow">→</span>
      </a>
    </div>
  </section>

  <EmblemGenerator client:load />
</Shell>
