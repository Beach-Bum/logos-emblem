---
import Shell from "../layouts/Shell.astro";
import EmblemGenerator from "../components/EmblemGenerator.tsx";
---
<Shell>
  <section class="hero">
    <span class="hero__tag">/emblem</span>
    <h1 class="hero__title">Memes shape reality, emblems define identity.</h1>
    <p class="hero__desc">
      Pick or upload an image, add text, apply filters, overlay the lambda. Downloads as PNG.
    </p>
  </section>

  <EmblemGenerator client:load />
</Shell>
